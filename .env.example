# AI Twin backend. When unset, the widget uses the client-side mock.
# For production on Vercel set this to /api/ai-twin
# VITE_AI_TWIN_ENDPOINT=/api/ai-twin

# --- Server-side (Vercel project env, NOT exposed to the client) ---
# Required for api/ai-twin.ts:
# ANTHROPIC_API_KEY=sk-ant-...
#
# Optional: durable rate limiting via Upstash Redis (free tier is enough).
# Without these, an in-memory per-instance limiter is used.
# UPSTASH_REDIS_REST_URL=https://....upstash.io
# UPSTASH_REDIS_REST_TOKEN=...
#
# Optional: lock the endpoint to your domains (comma-separated).
# AI_TWIN_ALLOWED_ORIGINS=https://alex-bes.vercel.app
